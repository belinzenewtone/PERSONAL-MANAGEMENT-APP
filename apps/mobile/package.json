{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "patch-package && expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:preview": "npx eas-cli build --profile preview --platform android",
    "build:production": "npx eas-cli build --profile production --platform android",
    "ota:preview": "npx eas-cli update --channel preview",
    "ota:production": "npx eas-cli update --channel production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@personal-os/types": "*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "date-fns": "^4.1.0",
    "expo": "~55.0.5",
    "expo-background-task": "~55.0.9",
    "expo-blur": "~55.0.9",
    "expo-build-properties": "^55.0.9",
    "expo-constants": "^55.0.7",
    "expo-file-system": "~55.0.10",
    "expo-image-picker": "~55.0.12",
    "expo-local-authentication": "~55.0.8",
    "expo-notifications": "~55.0.12",
    "expo-router": "~55.0.5",
    "expo-secure-store": "^55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-task-manager": "^55.0.9",
    "expo-updates": "~55.0.13",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.2.2",
    "react": "19.2.4",
    "react-hook-form": "^7.71.2",
    "react-native": "0.83.2",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-get-sms-android": "^2.1.0",
    "react-native-reanimated": "4.2.2",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.24.0",
    "react-native-svg": "^15.15.3",
    "react-native-worklets": "0.7.4",
    "tailwindcss": "^3.4.19",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-native-reanimated",
        "react-native-safe-area-context",
        "react-native-screens",
        "react-native-worklets"
      ]
    }
  }
}
